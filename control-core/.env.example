# Example environment variables for control-core
# Copy to .env and fill values for production

# Database
DATABASE_URL=postgresql://postgres:postgres@db/control_core

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=your-super-secret-key-change-it-in-prod
API_V1_STR=/api/v1
FRONTEND_URL=http://localhost:3000

# Email (development uses MailHog defaults if running via docker-compose)
SMTP_SERVER=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@control-center.local

# Updates (GitHub Releases)
# You can also set this at runtime via DB setting key: `github_repo`
GITHUB_REPO=infinityambients-tech/Control_center
# Optional token to avoid rate limits / support private repos
# You can also set this at runtime via DB setting key: `github_token`
GITHUB_TOKEN=

# For production example (SendGrid):
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
# EMAIL_FROM=notifications@your-domain.com

# Gmail example (recommended: use App Password with Google Account 2FA)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=YOUR_GOOGLE_APP_PASSWORD
# EMAIL_FROM=your-email@gmail.com
